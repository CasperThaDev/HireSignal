# HireSignal — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Anthropic Claude API (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Scan settings
MAX_DAYS=90
MIN_SIGNAL=medium

# Your agency details (used in outreach drafts)
YOUR_PRODUCT=HireSignal
YOUR_VALUE_PROP=identifies $9k/mo in automation gaps for Series A SaaS teams

# Security
# Run: python security/keygen.py to generate this
ENCRYPTION_KEY=

# Optional: Supabase (for persistent storage)
SUPABASE_URL=
SUPABASE_KEY=
